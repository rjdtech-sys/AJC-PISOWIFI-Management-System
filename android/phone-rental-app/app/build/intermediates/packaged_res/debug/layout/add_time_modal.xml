<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/modal_background"
    android:gravity="center">

    <!-- Connection Status -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <View
            android:id="@+id/connectionDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/green_dot"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/connectionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hardware Active"
            android:textColor="#4CAF50"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />
    </LinearLayout>

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="➕ ADD TIME"
        android:textColor="#ffffff"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Listening for physical pulses"
        android:textColor="#b0b0b0"
        android:textSize="11sp"
        android:layout_marginBottom="20dp" />

    <!-- Countdown Timer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/countdown_bg"
        android:padding="20dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REMAINING TIME"
            android:textColor="#ffffff"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:alpha="0.7"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/countdownTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="60s"
            android:textColor="#ffffff"
            android:textSize="48sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- Credits & Minutes -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#1a1a2e"
            android:padding="16dp"
            android:layout_marginEnd="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CREDITS"
                android:textColor="#808080"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/modalPesos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱0"
                android:textColor="#ffffff"
                android:textSize="32sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#1a1a2e"
            android:padding="16dp"
            android:layout_marginStart="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MINUTES"
                android:textColor="#808080"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/modalMinutes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#ffffff"
                android:textSize="32sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Coinslot Name -->
    <TextView
        android:id="@+id/modalCoinslotName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#FF9800"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- Done Paying Button -->
    <Button
        android:id="@+id/modalDonePaying"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:backgroundTint="#FF9800"
        android:text="DONE PAYING - ADD TIME"
        android:textColor="#ffffff"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- Cancel Button -->
    <Button
        android:id="@+id/modalCancel"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:backgroundTint="#333333"
        android:text="CANCEL"
        android:textColor="#b0b0b0"
        android:textSize="12sp"
        android:textStyle="bold" />

</LinearLayout>

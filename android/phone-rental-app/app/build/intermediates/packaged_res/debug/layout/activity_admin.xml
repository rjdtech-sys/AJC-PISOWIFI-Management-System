<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a2e"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔧 Admin Panel"
            android:textColor="#ffffff"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/deviceOwnerStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Device Owner: checking..."
            android:textColor="#808080"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/allowedCountLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="0 apps allowed for rental"
            android:textColor="#4CAF50"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Tab Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp">

        <Button
            android:id="@+id/tabCommon"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#0f3460"
            android:text="Popular"
            android:textColor="#ffffff"
            android:textSize="11sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/tabAll"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:backgroundTint="#333333"
            android:text="All Apps"
            android:textColor="#ffffff"
            android:textSize="11sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/tabSettings"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:backgroundTint="#333333"
            android:text="Settings"
            android:textColor="#ffffff"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- App List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/appRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Settings Container (hidden by default) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/settingsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <!-- Admin PIN -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Admin PIN"
                android:textColor="#ffffff"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/passwordInput"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="#0f3460"
                    android:hint="Enter 4+ digit PIN"
                    android:inputType="numberPassword"
                    android:paddingHorizontal="12dp"
                    android:textColor="#ffffff"
                    android:textColorHint="#808080"
                    android:textSize="16sp" />

                <Button
                    android:id="@+id/savePasswordBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="#4CAF50"
                    android:text="Save"
                    android:textColor="#ffffff"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Server URL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Server URL"
                android:textColor="#ffffff"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/serverUrlInput"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="#0f3460"
                    android:hint="http://10.0.0.1"
                    android:inputType="textUri"
                    android:paddingHorizontal="12dp"
                    android:textColor="#ffffff"
                    android:textColorHint="#808080"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/saveServerBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="#4CAF50"
                    android:text="Save"
                    android:textColor="#ffffff"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Action Buttons -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Device Management"
                android:textColor="#ffffff"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/testRestrictionsBtn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="#FF9800"
                android:text="🔒 Test App Restrictions"
                android:textColor="#ffffff"
                android:textSize="13sp" />

            <Button
                android:id="@+id/removeRestrictionsBtn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="#4CAF50"
                android:text="🔓 Remove All Restrictions"
                android:textColor="#ffffff"
                android:textSize="13sp" />

            <Button
                android:id="@+id/logoutAccountsBtn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="#f44336"
                android:text="🚪 Log Out All Accounts"
                android:textColor="#ffffff"
                android:textSize="13sp" />

            <!-- Kiosk Mode Controls -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Kiosk Mode"
                android:textColor="#ffffff"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Stop kiosk mode to return to normal phone mode.\nTimer will keep running in background."
                android:textColor="#808080"
                android:textSize="11sp" />

            <Button
                android:id="@+id/logoutKioskBtn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="#9C27B0"
                android:text="🔓 Logout Kiosk Mode"
                android:textColor="#ffffff"
                android:textSize="13sp" />

            <Button
                android:id="@+id/setupBtn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="#0f3460"
                android:text="⚙️ Device Setup"
                android:textColor="#ffffff"
                android:textSize="13sp" />

            <!-- Wallpaper Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Wallpaper"
                android:textColor="#ffffff"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Set a custom wallpaper for this rental device"
                android:textColor="#808080"
                android:textSize="11sp" />

            <Button
                android:id="@+id/setWallpaperBtn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="#E91E63"
                android:text="🖼️ Set Wallpaper"
                android:textColor="#ffffff"
                android:textSize="13sp" />

            <Button
                android:id="@+id/refreshWallpaperBtn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="#FF9800"
                android:text="🔄 Refresh Wallpaper"
                android:textColor="#ffffff"
                android:textSize="13sp" />

            <!-- App Update Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="App Update"
                android:textColor="#ffffff"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/appVersionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Current version: loading..."
                android:textColor="#808080"
                android:textSize="11sp" />

            <Button
                android:id="@+id/checkUpdateBtn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="#1565C0"
                android:text="🔄 Check for Updates"
                android:textColor="#ffffff"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/updateStatusLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text=""
                android:textColor="#4CAF50"
                android:textSize="11sp" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <Button
            android:id="@+id/backBtn"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:backgroundTint="#333333"
            android:text="← Back to Kiosk"
            android:textColor="#ffffff"
            android:textSize="14sp" />
    </LinearLayout>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Wallpaper Background ImageView -->
    <ImageView
        android:id="@+id/wallpaperImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:adjustViewBounds="true"
        android:visibility="gone" />

    <!-- Main Content (on top of wallpaper) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:fitsSystemWindows="false"
        android:orientation="vertical">

        <!-- Connection Status Bar -->
        <TextView
            android:id="@+id/connectionStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#0f3460"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            android:paddingVertical="6dp"
            android:text="Connecting..."
            android:textColor="#e0e0e0"
            android:textSize="11sp"
            android:textStyle="bold" />

        <!-- Status Label -->
        <TextView
            android:id="@+id/statusLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginVertical="6dp"
            android:background="@drawable/status_badge"
            android:paddingHorizontal="20dp"
            android:paddingVertical="6dp"
            android:text="CHECKING..."
            android:textColor="#ffffff"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- IDLE STATE - Device Available (LANDSCAPE) -->
        <LinearLayout
            android:id="@+id/idleContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone"
            android:padding="24dp">

            <!-- Left side: Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <!-- Phone Icon -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📱"
                    android:textSize="100sp" />

                <TextView
                    android:id="@+id/deviceNameLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Phone"
                    android:textColor="#ffffff"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Available for Rental"
                    android:textColor="#4CAF50"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:text="Please approach the counter\nto start your rental session"
                    android:textColor="#b0b0b0"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- Right side: Insert Coin Section -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="32dp">

                <!-- INSERT COIN SECTION -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#0f3460"
                    android:padding="20dp"
                    android:layout_margin="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💰 INSERT COIN"
                        android:textColor="#FFD700"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_gravity="center" />

                    <TextView
                        android:id="@+id/coinAccumulatedLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₱0.00"
                        android:textColor="#ffffff"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp"
                        android:layout_gravity="center" />

                    <TextView
                        android:id="@+id/coinTimeLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 minutes"
                        android:textColor="#4CAF50"
                        android:textSize="18sp"
                        android:layout_marginTop="8dp"
                        android:layout_gravity="center" />

                    <Button
                        android:id="@+id/insertCoinButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="INSERT COIN"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp"
                        android:backgroundTint="#FFD700"
                        android:textColor="#000000" />

                    <Button
                        android:id="@+id/donePayingButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="DONE PAYING - START SESSION"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp"
                        android:backgroundTint="#4CAF50"
                        android:textColor="#ffffff"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ACTIVE STATE - Timer Running (LANDSCAPE) -->
        <LinearLayout
            android:id="@+id/activeContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone"
            android:padding="32dp">

            <!-- Left side: Timer -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱️"
                    android:textSize="80sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Time Remaining"
                    android:textColor="#b0b0b0"
                    android:textSize="18sp"
                    android:layout_marginTop="16dp" />

                <TextView
                    android:id="@+id/timerDisplay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00:00"
                    android:textColor="#ffffff"
                    android:textSize="72sp"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp"
                    android:fontFamily="monospace" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:progressTint="#4CAF50" />

                <Button
                    android:id="@+id/addTimeButton"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="#FF9800"
                    android:text="➕ ADD TIME"
                    android:textColor="#ffffff"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Right side: Session Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋 Session Info"
                    android:textColor="#FFD700"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/customerNameLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Customer"
                    android:textColor="#ffffff"
                    android:textSize="20sp"
                    android:layout_marginTop="16dp" />

                <TextView
                    android:id="@+id/rateLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rate: --"
                    android:textColor="#b0b0b0"
                    android:textSize="16sp"
                    android:layout_marginTop="12dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- EXPIRED STATE (LANDSCAPE) -->
        <LinearLayout
            android:id="@+id/expiredContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏰"
                android:textSize="100sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Rental Time Expired"
                android:textColor="#FF5722"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Your rental session has ended.\nPlease return the phone to the counter."
                android:textColor="#e0e0e0"
                android:textSize="18sp"
                android:gravity="center" />

            <Button
                android:id="@+id/refreshStatusBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:backgroundTint="#4CAF50"
                android:text="🔄 Check Availability"
                android:textColor="#ffffff"
                android:textSize="14sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Admin Button (visible always for easy access) -->
    <Button
        android:id="@+id/adminButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start|bottom"
        android:layout_margin="12dp"
        android:backgroundTint="#9C27B0"
        android:text="🔐 Admin"
        android:textColor="#ffffff"
        android:textSize="11sp"
        android:visibility="visible" />

    <!-- Setup Button -->
    <Button
        android:id="@+id/setupButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:layout_margin="12dp"
        android:backgroundTint="#0f3460"
        android:text="Setup"
        android:textColor="#ffffff"
        android:textSize="11sp"
        android:visibility="gone" />

</FrameLayout>
